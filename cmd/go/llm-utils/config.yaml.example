# --- LLM Go Utilities Configuration ---
# Copy this file to config.yaml and update for your environment

# --- Ollama Settings ---
# Used for vision analysis and text generation
ollama:
  # Base API URL for Ollama (standard endpoint is http://127.0.0.1:11434)
  api_url: "http://127.0.0.1:11434"
  # Default model for standard chat/completions
  base_model: "llama3.2"
  # Default vision-capable model to use
  vision_model: "llama3.2-vision:latest"

# --- Stable Diffusion Forge Settings ---
# Used for image generation automation
forge:
  # Base API URL for Forge (standard endpoint is /sdapi/v1)
  api_url: "http://127.0.0.1:7861/sdapi/v1"
  # Default SDXL base model to use
  base_model: "Juggernaut-XL_v9_RunDiffusionPhoto_v2.safetensors"
  # Available LoRAs for injection
  loras:
    - "Example_Style_v1.safetensors"
    - "Character_Detail_Slider.safetensors"

# --- AnythingLLM RAG Settings ---
# Primary storage for analysis results
anythingllm:
  # Base API URL for AnythingLLM (/api/v1)
  api_url: "http://127.0.0.1:3001/api/v1"
  # Your AnythingLLM API Key
  api_key: "YOUR_ANYTHING_LLM_API_KEY_HERE"
  # Target workspace slug
  workspace_slug: "ai-image-research"

# --- Onyx RAG Settings ---
# Alternative RAG provider
onyx:
  # API URL for Onyx
  api_url: "http://localhost:3000"
  # Your Onyx API Key
  api_key: "YOUR_ONYX_API_KEY_HERE"
  # Default persona identifier
  persona_id: 0
  # Default project identifier
  project_id: 0

# --- Kohya_ss Integration ---
# Path configuration for LoRA training scripts
kohya:
  # Root directory of kohya_ss repo
  root_path: "/path/to/kohya_ss"
  # Virtual environment path
  venv_path: "/path/to/kohya_ss/venv"
  # Default training JSON configuration template
  default_config: "/path/to/LoRA_Project/model/config.json"

# --- Quant Analysis Settings ---
# Parameters for financial market analysis and strategy generation
quant:
  # LLM Model used for qualitative analysis
  analyst_model: "deepseek-r1:32b"
  # LLM Model used for Pine Script coding
  coder_model: "qwen2.5-coder:32b"
  # Preferred RAG provider ("anything" or "onyx")
  rag_provider: "anything"
  # Strategy logic categories
  logics:
    - "mean reversion"
    - "trend following"
    - "ema crossover"
    - "rsi breakout"
    - "macd divergence"
    - "bollinger band squeeze"
