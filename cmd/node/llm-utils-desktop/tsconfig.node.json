{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "../../../internal/node/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": [
      "electron-vite/node",
      "node"
    ],
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "paths": {
      "@internal/*": [
        "../../../internal/node/*"
      ]
    }
  }
}
